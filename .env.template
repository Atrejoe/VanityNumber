# Sentry Configuration Template
# Copy this to .env and fill in your actual DSN values
# DO NOT commit .env file to version control!

# ==============================================
# FRONT-END (Blazor WebAssembly)
# ==============================================
# Configure in: VanityNumber.Web/wwwroot/appsettings.Production.json
# Note: Front-end DSN will be visible in browser (this is normal)
SENTRY_WEB_DSN=https://your-frontend-dsn@sentry.io/project-id

# ==============================================
# BACKEND (ASP.NET Core API)
# ==============================================
# Configure in: VanityNumber.Api/appsettings.Production.json
# Or via environment variable: Sentry__Dsn
SENTRY_API_DSN=https://your-backend-dsn@sentry.io/project-id

# ==============================================
# OPTIONAL: Docker Compose Override
# ==============================================
# For Docker deployments, add these to docker-compose.override.yml:
#
# services:
#   vanity-api:
#     environment:
#       - Sentry__Dsn=${SENTRY_API_DSN}
#       - Sentry__Environment=Production
#       - Sentry__TracesSampleRate=0.1
#
# Note: Front-end DSN must be in appsettings.Production.json at build time

# ==============================================
# OPTIONAL: Kubernetes Secrets
# ==============================================
# For Kubernetes, create secrets:
#
# kubectl create secret generic sentry-config \
#   --from-literal=api-dsn=${SENTRY_API_DSN}
#
# Then reference in deployment:
#
# env:
#   - name: Sentry__Dsn
#     valueFrom:
#       secretKeyRef:
#         name: sentry-config
#         key: api-dsn
