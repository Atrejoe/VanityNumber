@page "/"
@using VanityNumber.Web.Services
@using VanityNumber.Web.Components
@using Microsoft.AspNetCore.Components
@inject VanityNumberService ApiService
@inject IJSRuntime JSRuntime

<PageTitle>Vanity Number Generator</PageTitle>

<ThemeSelector />

<div class="app-container">
    <div class="header">
        <div class="header-content">
            <h1>📞 Vanity Number Generator</h1>
            <p>Transform your phone number into memorable words</p>
        </div>
    </div>

    <div class="main-content">
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-error">
                <span>⚠️</span>
                <div>
                    <strong>Error:</strong> @errorMessage
                    @if (!string.IsNullOrEmpty(errorDetails))
                    {
                        <details style="margin-top: 0.5rem;">
                            <summary style="cursor: pointer;">Show details</summary>
                            <pre style="margin-top: 0.5rem; padding: 0.5rem; background: rgba(0,0,0,0.1); border-radius: 0.25rem; overflow-x: auto; font-size: 0.75rem;">@errorDetails</pre>
                        </details>
                    }
                </div>
            </div>
        }

        <div class="card">
            <EditForm Model="@request" OnValidSubmit="@HandleSubmit">
                <DataAnnotationsValidator />

                <div class="form-group">
                    <label class="form-label">Phone Number</label>
                    <div style="display: flex; gap: 0.5rem; align-items: stretch;">
                        <InputText @ref="phoneNumberInput"
                                   @bind-Value="request.PhoneNumber" 
                                   class="form-input" 
                                   style="flex: 1;"
                                   placeholder="e.g., 555-1234 or 0612345678" />
                        @if (isContactPickerSupported)
                        {
                            <button type="button" 
                                    class="btn btn-secondary" 
                                    @onclick="SelectFromContacts"
                                    style="white-space: nowrap; padding: 0.5rem 1rem;"
                                    title="Select from contacts">
                                📇 Contacts
                            </button>
                        }
                    </div>
                    <ValidationMessage For="@(() => request.PhoneNumber)" />
                </div>

                <div class="form-group">
                    <label class="form-label">Dictionaries</label>
                    <div class="checkbox-group">
                        <label class="checkbox-label">
                            <input type="checkbox" 
                                   checked="@useDutch" 
                                   @onchange="@((e) => ToggleDictionary(DictionaryType.Dutch, (bool)e.Value!))" />
                            <span>🇳🇱 Dutch</span>
                        </label>
                        <label class="checkbox-label">
                            <input type="checkbox" 
                                   checked="@useEnglish" 
                                   @onchange="@((e) => ToggleDictionary(DictionaryType.English, (bool)e.Value!))" />
                            <span>🇬🇧 English</span>
                        </label>
                        <label class="checkbox-label">
                            <input type="checkbox" 
                                   checked="@useUrban" 
                                   @onchange="@((e) => ToggleDictionary(DictionaryType.Urban, (bool)e.Value!))" />
                            <span>🌆 Urban</span>
                        </label>
                    </div>
                </div>

                <div class="form-group">
                    <label class="checkbox-label">
                        <InputCheckbox @bind-Value="request.UseLeetSpeak" />
                        <span>Use Leet Speak (0=O, 1=I/L, 4=A, 5=S, 7=T, 8=B)</span>
                    </label>
                </div>

                <div class="form-group">
                    <label class="form-label">Maximum Results</label>
                    <InputNumber @bind-Value="request.MaxResults" 
                                 class="form-input" 
                                 min="1" 
                                 max="100" />
                </div>

                <button type="submit" class="btn btn-primary btn-block" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="loading"></span>
                        <span>Generating...</span>
                    }
                    else
                    {
                        <span>✨ Generate Vanity Numbers</span>
                    }
                </button>
            </EditForm>
        </div>

        @if (result != null)
        {
            <div class="card">
                <div class="results-header">
                    <h2 style="margin: 0;">Results</h2>
                    <span class="results-count">Found @result.Matches.Count match@(result.Matches.Count != 1 ? "es" : "")</span>
                </div>

                @if (result.Matches.Any())
                {
                    foreach (var match in result.Matches)
                    {
                        <div class="result-item">
                            <div class="vanity-number">@match.VanityNumber</div>
                            <div>
                                <span class="word-badge">@match.Word.ToUpper()</span>
                            </div>
                            <div class="dictionary-badges">
                                @if ((match.DictionaryType & DictionaryType.Dutch) != 0)
                                {
                                    <span class="dict-badge dict-dutch">Dutch</span>
                                }
                                @if ((match.DictionaryType & DictionaryType.English) != 0)
                                {
                                    <span class="dict-badge dict-english">English</span>
                                }
                                @if ((match.DictionaryType & DictionaryType.Urban) != 0)
                                {
                                    <span class="dict-badge dict-urban">Urban</span>
                                }
                            </div>
                            <div class="result-meta">
                                Position: @match.StartPosition | Length: @match.Length digits
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="empty-state">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        <p>No vanity numbers found. Try a different phone number or enable more dictionaries.</p>
                    </div>
                }
            </div>
        }
    </div>

    <div class="footer">
        <p>Powered by Vanity Number API</p>
    </div>
</div>

@code {
    private readonly VanityNumberRequest request = new();
    private VanityNumberResult? result;
    private string errorMessage = string.Empty;
    private string errorDetails = string.Empty;
    private bool isLoading = false;
    private InputText? phoneNumberInput;
    private bool isContactPickerSupported = false;

    private bool useDutch = true;
    private bool useEnglish = true;
    private bool useUrban = false;

    protected override void OnInitialized()
    {
        request.DictionaryTypes = DictionaryType.Dutch | DictionaryType.English;
        request.MaxResults = 20;
        request.MinWordLength = 3;
        request.PhoneNumber = string.Empty;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Check if Contact Picker API is supported
            try
            {
                isContactPickerSupported = await JSRuntime.InvokeAsync<bool>("contactPicker.isSupported");
                StateHasChanged();
            }
            catch
            {
                // If the check fails, assume not supported
                isContactPickerSupported = false;
            }

            // Focus the phone number input
            if (phoneNumberInput?.Element is not null)
            {
                try
                {
                    await phoneNumberInput.Element.Value.FocusAsync();
                }
                catch
                {
                    // Silently ignore focus errors
                }
            }
        }
    }

    private async Task SelectFromContacts()
    {
        try
        {
            var phoneNumber = await JSRuntime.InvokeAsync<string>("contactPicker.pickContact");
            
            if (!string.IsNullOrEmpty(phoneNumber))
            {
                request.PhoneNumber = phoneNumber;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Failed to access contacts.";
            errorDetails = $"The Contact Picker API may not be supported or permission was denied.\n\nTechnical details:\n{ex.Message}";
        }
    }

    private void ToggleDictionary(DictionaryType dict, bool isChecked)
    {
        if (isChecked)
        {
            request.DictionaryTypes |= dict;
        }
        else
        {
            request.DictionaryTypes &= ~dict;
        }

        useDutch = (request.DictionaryTypes & DictionaryType.Dutch) != 0;
        useEnglish = (request.DictionaryTypes & DictionaryType.English) != 0;
        useUrban = (request.DictionaryTypes & DictionaryType.Urban) != 0;
    }

    private async Task HandleSubmit()
    {
        errorMessage = string.Empty;
        errorDetails = string.Empty;
        result = null;
        isLoading = true;

        try
        {
            if (string.IsNullOrWhiteSpace(request.PhoneNumber))
            {
                errorMessage = "Please enter a phone number.";
                return;
            }

            if (request.DictionaryTypes == DictionaryType.None)
            {
                errorMessage = "Please select at least one dictionary.";
                return;
            }

            result = await ApiService.ConvertToVanityNumberAsync(request);

            if (result == null)
            {
                errorMessage = "The API returned no data. Please check if the API is running.";
            }
        }
        catch (HttpRequestException ex)
        {
            errorMessage = "Failed to connect to the API.";
            errorDetails = $"Make sure the API is running at the configured URL.\n\nTechnical details:\n{ex.Message}";
        }
        catch (Exception ex)
        {
            errorMessage = "An unexpected error occurred.";
            errorDetails = $"Type: {ex.GetType().Name}\nMessage: {ex.Message}\n\nStack Trace:\n{ex.StackTrace}";
        }
        finally
        {
            isLoading = false;
        }
    }
}
